# Ross backend local development
PORT=8787
ROSS_PUBLIC_BASE_URL=http://127.0.0.1:8787

# Public-law search connector
ROSS_PUBLIC_LAW_GEMINI_API_KEY=
ROSS_PUBLIC_LAW_GEMINI_MODEL=gemini-2.5-flash-lite

# Optional mobile redirect override
# ROSS_AUTH_MOBILE_REDIRECT=ross://auth/callback

# Model catalog/downloads
# production_metadata advertises real iOS Gemma 4 Q4 packs and Android MediaPipe .task packs.
ROSS_MODEL_CATALOG_MODE=production_metadata
ROSS_HUGGING_FACE_ACCESS_TOKEN=
