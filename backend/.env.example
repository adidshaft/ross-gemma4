# Ross backend local development
PORT=8787
ROSS_PUBLIC_BASE_URL=http://127.0.0.1:8787

# Public-law search connector
ROSS_PUBLIC_LAW_GEMINI_API_KEY=
ROSS_PUBLIC_LAW_GEMINI_MODEL=gemini-2.5-flash

# Optional mobile redirect override
# ROSS_AUTH_MOBILE_REDIRECT=ross://auth/callback

# Model catalog mode
# dev keeps tiny deterministic artifacts for CI and local tests.
# production_metadata advertises Gemma 4 E2B Q4 Gemma 4 Q4 tier metadata without serving large model files.
ROSS_MODEL_CATALOG_MODE=dev
