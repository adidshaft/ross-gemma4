{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ross.local/domain.schema.json",
  "title": "Ross Shared Domain Schema",
  "type": "object",
  "definitions": {
    "modelCapabilityTierId": {
      "type": "string",
      "enum": [
        "quick_start",
        "case_associate",
        "senior_drafting"
      ]
    },
    "privacyLedgerEntry": {
      "type": "object",
      "required": [
        "id",
        "timestamp",
        "purpose",
        "payloadClass",
        "endpointLabel",
        "success"
      ],
      "properties": {
        "id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "purpose": {
          "type": "string",
          "enum": [
            "entitlement_check",
            "model_catalog",
            "model_download",
            "model_verification",
            "public_law_search"
          ]
        },
        "payloadClass": {
          "type": "string",
          "enum": [
            "no_case_data",
            "sanitized_public_query",
            "account_token"
          ]
        },
        "endpointLabel": { "type": "string" },
        "success": { "type": "boolean" }
      }
    }
  }
}

